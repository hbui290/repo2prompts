# OpenAI-compatible chat provider.
# Examples:
# - local:      MODEL_BASE_URL=http://127.0.0.1:20128/v1
# - Groq:       MODEL_BASE_URL=https://api.groq.com/openai/v1
# - OpenRouter: MODEL_BASE_URL=https://openrouter.ai/api/v1
# - Gemini via OpenAI-compatible gateway: MODEL_BASE_URL=https://your-gateway/v1
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_CHAT_ID=

# Optional task-specific overrides. Fall back to MODEL_CHAT_ID.
# Recommended: cheap/fast model for analysis, stronger model for writing.
MODEL_ANALYSIS_ID=
MODEL_WRITER_ID=
MODEL_REQUEST_TIMEOUT_MS=90000

# Optional. Anonymous GitHub API access has lower rate limits.
GITHUB_API_TOKEN=

# Optional durable cache. Use a server-only service key.
DATABASE_REST_URL=
DATABASE_SERVICE_KEY=

# Basic server-side generation abuse control.
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_DB_FAILURE_MODE=open
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=10

# Public metadata and future ads placeholders. Leave ads empty until configured.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_ADS_PROVIDER=
NEXT_PUBLIC_ADS_CLIENT_ID=
