{
  "mcpServers": {
    "github-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "$typeName": "exa.cascade_plugins_pb.CascadePluginCommandTemplate"
    },
    "depwire": {
      "command": "npx",
      "args": [
        "-y",
        "depwire-cli",
        "mcp"
      ]
    },
    "api-testing-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "api-testing-mcp"
      ]
    },
    "deepwiki-official": {
      "serverUrl": "https://mcp.deepwiki.com/mcp"
    },
    "mcp-deepwiki": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-deepwiki@latest"
      ]
    },
    "superpowers-mcp": {
      "command": "node",
      "args": [
        "/Users/winston/.gemini/antigravity-ide/mcp-tools/superpowers-mcp/build/index.js"
      ],
      "env": {
        "SUPERPOWERS_SKILLS_DIR": "/Users/winston/.config/superpowers-mcp/superpowers/skills"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@langgpt/sequential-thinking-mcp"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/winston/Documents/VM-Shared-Safe/repo2prompt-clean"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "--package=next-devtools-mcp",
        "next-devtools-mcp"
      ]
    }
  }
}
